---
import EsperienciaItem from "./EsperienciaItem.astro";

const EXPERIENCIAS = [
    {
        data: "Febrero 2026 - Actualidad",
        title: "Página Web para la empresa 'ES Piel Calma'",
        description:
            "Creación de una página web para la empresa ES Piel Calma, con el objetivo de mostrar sus productos y servicios. Se trabajó en el diseño responsivo y la integración de catálogos.",
        link: "https://espielcalma.com/",
        image: "/images/esPielcalma.jpeg",
        images: ["/images/esPielcalma.jpeg", "/images/esPielcalma.jpeg"], // Agrega aquí más imágenes si las tienes
    },
];
---

<ol class="relative border-s border-default text-white">
    {
        EXPERIENCIAS.map((experiencia) => {
            return (
                <li class="mb-10 ms-4 reveal">
                    <EsperienciaItem {...experiencia} />
                </li>
            );
        })
    }
</ol>

<!-- Modal / Carrousel para Experiencias -->
<dialog
    id="experience-modal"
    class="fixed inset-0 m-auto bg-transparent backdrop:bg-black/95 border-none outline-none p-0 overflow-hidden rounded-3xl max-w-[95vw] w-full max-h-[90vh] reveal z-50"
>
    <div
        class="relative w-full h-full flex flex-col md:flex-row bg-[#0a0a0a] border border-white/10 rounded-3xl overflow-hidden shadow-2xl"
    >
        <!-- Lado del Carrusel -->
        <div
            class="relative w-full md:w-2/3 h-[40vh] md:h-auto bg-black overflow-hidden group/exp-carousel"
        >
            <div
                id="exp-track"
                class="flex h-full transition-transform duration-500 ease-out"
            >
                <!-- Imágenes inyectadas -->
            </div>

            <button
                id="exp-prev"
                class="absolute left-4 top-1/2 -translate-y-1/2 bg-white/5 hover:bg-white/10 text-white p-3 rounded-full backdrop-blur-md border border-white/10 opacity-0 group-hover/exp-carousel:opacity-100 transition-opacity z-30"
            >
                <svg
                    class="size-6"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    ><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M15 19l-7-7 7-7"></path></svg
                >
            </button>
            <button
                id="exp-next"
                class="absolute right-4 top-1/2 -translate-y-1/2 bg-white/5 hover:bg-white/10 text-white p-3 rounded-full backdrop-blur-md border border-white/10 opacity-0 group-hover/exp-carousel:opacity-100 transition-opacity z-30"
            >
                <svg
                    class="size-6"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    ><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M9 5l7 7-7 7"></path></svg
                >
            </button>

            <div
                id="exp-dots"
                class="absolute bottom-6 left-1/2 -translate-x-1/2 flex gap-2 z-30"
            >
            </div>
        </div>

        <!-- Lado de Información -->
        <div
            class="w-full md:w-1/3 p-6 md:p-10 flex flex-col justify-between bg-[#0f0f0f] border-t md:border-t-0 md:border-l border-white/5"
        >
            <div>
                <time
                    id="exp-date"
                    class="text-sm font-mono text-blue-500 mb-2 block"></time>
                <h3 id="exp-title" class="text-2xl font-bold text-white mb-4">
                </h3>
                <p
                    id="exp-desc"
                    class="text-gray-400 text-base leading-relaxed mb-8"
                >
                </p>
            </div>

            <div id="exp-links" class="flex flex-col gap-3"></div>
        </div>

        <button
            id="close-exp-modal"
            class="absolute top-4 right-4 bg-white/5 hover:bg-white/10 backdrop-blur-md text-white rounded-full p-2 transition-all border border-white/10 z-50"
        >
            <svg
                class="size-6"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M6 18L18 6M6 6l12 12"></path>
            </svg>
        </button>
    </div>
</dialog>

<script>
    interface Experience {
        title: string;
        description: string;
        images: string[];
        data: string;
        link?: string;
    }

    const modal = document.getElementById(
        "experience-modal",
    ) as HTMLDialogElement;
    const track = document.getElementById("exp-track");
    const dotsContainer = document.getElementById("exp-dots");
    const titleEl = document.getElementById("exp-title");
    const dateEl = document.getElementById("exp-date");
    const descEl = document.getElementById("exp-desc");
    const linksEl = document.getElementById("exp-links");
    const prevBtn = document.getElementById("exp-prev");
    const nextBtn = document.getElementById("exp-next");
    const closeBtn = document.getElementById("close-exp-modal");

    let currentIndex = 0;
    let currentExp: Experience | null = null;

    function updateCarousel() {
        if (!track || !currentExp) return;
        track.style.transform = `translateX(-${currentIndex * 100}%)`;
        const dots = dotsContainer?.querySelectorAll("div");
        dots?.forEach((dot, idx) => {
            if (idx === currentIndex) {
                dot.classList.add("bg-white", "w-6");
                dot.classList.remove("bg-white/30", "w-2");
            } else {
                dot.classList.remove("bg-white", "w-6");
                dot.classList.add("bg-white/30", "w-2");
            }
        });
    }

    document.querySelectorAll(".experience-trigger").forEach((trigger) => {
        trigger.addEventListener("click", () => {
            const data = (trigger as HTMLElement).dataset.experience;
            if (!data || !modal) return;

            currentExp = JSON.parse(data);
            if (!currentExp) return;

            currentIndex = 0;
            if (track) {
                track.innerHTML = currentExp.images
                    .map(
                        (img) => `
                    <div class="min-w-full h-full flex items-center justify-center">
                        <img src="${img}" class="w-full h-full object-cover" />
                    </div>
                `,
                    )
                    .join("");
            }

            if (dotsContainer) {
                dotsContainer.innerHTML = currentExp.images
                    .map(
                        (_, i) => `
                    <div class="h-2 rounded-full transition-all duration-300 ${i === 0 ? "bg-white w-6" : "bg-white/30 w-2"}"></div>
                `,
                    )
                    .join("");
            }

            if (titleEl) titleEl.textContent = currentExp.title;
            if (dateEl) dateEl.textContent = currentExp.data;
            if (descEl) descEl.textContent = currentExp.description;
            if (linksEl) {
                linksEl.innerHTML = currentExp.link
                    ? `
                    <a href="${currentExp.link}" target="_blank" class="flex items-center justify-center gap-2 px-6 py-3 text-sm font-semibold text-black bg-white rounded-xl hover:bg-gray-200 transition-all">
                        Visitar Proyecto
                    </a>
                `
                    : "";
            }

            modal.showModal();
            modal.classList.add("active");
            updateCarousel();
        });
    });

    prevBtn?.addEventListener("click", () => {
        if (!currentExp) return;
        currentIndex =
            (currentIndex - 1 + currentExp.images.length) %
            currentExp.images.length;
        updateCarousel();
    });

    nextBtn?.addEventListener("click", () => {
        if (!currentExp) return;
        currentIndex = (currentIndex + 1) % currentExp.images.length;
        updateCarousel();
    });

    const closeAll = () => {
        modal?.close();
        modal?.classList.remove("active");
    };

    closeBtn?.addEventListener("click", closeAll);
    modal?.addEventListener("click", (e) => {
        if (e.target === modal) closeAll();
    });
</script>

<style>
    dialog::backdrop {
        background: rgba(0, 0, 0, 0.9);
        backdrop-filter: blur(8px);
    }
</style>
