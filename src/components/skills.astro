---
const skills = [
    {
        category: "Frontend",
        technologies: [
            { name: "React", icon: "devicon-react-original colored" },
            { name: "Tailwind", icon: "devicon-tailwindcss-original colored" },
            { name: "JavaScript", icon: "devicon-javascript-plain colored" },
            { name: "HTML5", icon: "devicon-html5-plain colored" },
            { name: "CSS3", icon: "devicon-css3-plain colored" },
            { name: "Astro", icon: "devicon-astro-plain colored" },
        ],
    },
    {
        category: "Backend",
        technologies: [
            { name: "Java", icon: "devicon-java-plain colored" },
            { name: "Python", icon: "devicon-python-plain colored" },
            { name: "Flask", icon: "devicon-flask-original colored" },
            { name: "Node.js", icon: "devicon-nodejs-plain colored" },
        ],
    },
    {
        category: "Base de Datos",
        technologies: [
            { name: "MySQL", icon: "devicon-mysql-plain colored" },
            { name: "MongoDB", icon: "devicon-mongodb-plain colored" },
        ],
    },
    {
        category: "Herramientas",
        technologies: [
            { name: "Git", icon: "devicon-git-plain colored" },
            { name: "GitHub", icon: "devicon-github-original" },
            { name: "VS Code", icon: "devicon-vscode-plain colored" },
        ],
    },
];
---

<link
    rel="stylesheet"
    type="text/css"
    href="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/devicon.min.css"
/>
<section id="habilidades" class="relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 relative z-10">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto">
            {
                skills.map((skillGroup) => (
                    <div class="bg-slate-900/50 backdrop-blur-sm border border-slate-700 rounded-xl p-6 hover:border-blue-500/50 transition-colors duration-300 reveal">
                        <h3 class="text-xl font-bold text-white mb-6 border-b border-slate-700 pb-2 flex items-center gap-2">
                            <span class="text-blue-500">#</span>{" "}
                            {skillGroup.category}
                        </h3>

                        <div class="grid grid-cols-3 gap-4">
                            {skillGroup.technologies.map((tech) => (
                                <div class="flex flex-col items-center justify-center p-4 bg-slate-800/50 rounded-xl hover:bg-slate-700/50 transition-colors border border-slate-700/50 hover:border-blue-500/30 group">
                                    <i
                                        class={`${tech.icon} text-4xl mb-3 group-hover:scale-110 transition-transform duration-300 ${tech.name === "GitHub" ? "text-white" : ""}`}
                                    />
                                    <span class="text-xs text-gray-400 font-medium text-center">
                                        {tech.name}
                                    </span>
                                </div>
                            ))}
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</section>
