---
import TecnologiaPill from "./TecnologiaPill.astro";
import Github from "./icons/github.astro";

const PROJECTS = [
    {
        title: "ParkScan",
        description: `Sistema automatizado para gestionar playas de estacionamiento que controla el ingreso y egreso de vehículos, monitorea la disponibilidad en tiempo real, gestiona pagos de forma segura y genera reportes para la toma de decisiones.`,
        link: "https://parkscan-ten.vercel.app/",
        github: "https://github.com/PenoffPablo/ParkScan",
        image: "/images/parkscand.jpeg",
        images: [
            "/images/parkscand.jpeg",
            "/images/parkscand.jpeg", // Duplicadas para ejemplo, el usuario puede cambiarlas
            "/images/parkscand.jpeg",
        ],
        tags: ["HTML", "Tailwind", "JavaScript", "React", "Supabase"],
    },
];
---

<div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-12 pb-10">
    {
        PROJECTS.map((project) => {
            const { title, description, image, tags, link, github } = project;
            return (
                <article class="flex flex-col group p-4 rounded-xl relative overflow-hidden bg-white/5 border border-white/10 reveal">
                    <div class="absolute inset-0 bg-white transition-all duration-1000 ease-out bg-[size:16px_16px] bg-[position:0_0,8px_8px] bg-[image:linear-gradient(45deg,#efefef_25%,rgba(239,239,239,0)_25%,rgba(239,239,239,0)_75%,#efefef_75%,#efefef),linear-gradient(45deg,#efefef_25%,rgba(239,239,239,0)_25%,rgba(239,239,239,0)_75%,#efefef_75%,#efefef)] [clip-path:polygon(0px_0px,0%_0px,0%_100%,0px_100%)]  z-0 pointer-events-none" />
                    <div class="relative z-10 flex flex-col h-full space-y-4">
                        <h3 class="text-2xl font-bold text-white transition-colors duration-500">
                            {title}
                        </h3>

                        <div class="w-full">
                            <div
                                class="relative transition duration-500 ease-in-out transform shadow-xl overflow-hidden rounded-xl sm:rounded-xl md:group-hover:-translate-y-1 md:group-hover:shadow-2xl border border-white/10 hover:border-white/20 hover:bg-white/5 cursor-zoom-in project-image-container"
                                data-project={JSON.stringify(project)}
                            >
                                <img
                                    class="object-cover object-top w-full h-56 transition duration-500 sm:h-full"
                                    src={image}
                                    alt={`Captura de pantalla del proyecto ${title}`}
                                />
                                <div class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center z-20">
                                    <span class="text-white font-medium bg-black/50 px-4 py-2 rounded-full backdrop-blur-sm border border-white/20">
                                        Ver Galería
                                    </span>
                                </div>
                            </div>
                        </div>

                        <div class="w-full flex flex-col justify-between flex-1">
                            <div>
                                <ul class="flex flex-wrap gap-2 mb-4 mt-2">
                                    {tags.map((tag) => (
                                        <li>
                                            <TecnologiaPill>{tag}</TecnologiaPill>
                                        </li>
                                    ))}
                                </ul>
                                <div class="mb-4 text-white/95 text-pretty">
                                    <p>{description}</p>
                                </div>
                            </div>

                            <footer class="flex items-end justify-start mt-4 gap-x-4">
                                {github && (
                                    <a
                                        href={github}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        class="flex items-center gap-2 px-4 py-2 text-sm font-medium transition text-white bg-white/5 border border-white/10 rounded-full hover:bg-white/10 hover:text-white"
                                    >
                                        <Github class="size-4" />
                                        Código
                                    </a>
                                )}
                                {link && (
                                    <a
                                        href={link}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        class="flex items-center gap-2 px-4 py-2 text-sm font-medium transition text-white bg-white/10 border border-white/10 rounded-full hover:bg-white/20 hover:text-white"
                                    >
                                        Saber más
                                        <svg
                                            class="size-4"
                                            aria-hidden="true"
                                            xmlns="http://www.w3.org/2000/svg"
                                            fill="none"
                                            viewBox="0 0 24 24"
                                        >
                                            <path
                                                stroke="currentColor"
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="2"
                                                d="M19 12H5m14 0-4 4m4-4-4-4"
                                            />
                                        </svg>
                                    </a>
                                )}
                            </footer>
                        </div>
                    </div>
                </article>
            );
        })
    }
</div>

<!-- Modal / Carrousel -->
<dialog
    id="project-modal"
    class="fixed inset-0 m-auto bg-transparent backdrop:bg-black/95 border-none outline-none p-0 overflow-hidden rounded-3xl max-w-[95vw] w-full max-h-[90vh] reveal z-50"
>
    <div class="relative w-full h-full flex flex-col md:flex-row bg-[#0a0a0a] border border-white/10 rounded-3xl overflow-hidden shadow-2xl">
        <!-- Lado del Carrusel -->
        <div class="relative w-full md:w-2/3 h-[50vh] md:h-auto bg-black overflow-hidden group/carousel">
            <div id="carousel-track" class="flex h-full transition-transform duration-500 ease-out">
                <!-- Las imágenes se inyectarán aquí -->
            </div>
            
            <!-- Botones de navegación -->
            <button id="prev-btn" class="absolute left-4 top-1/2 -translate-y-1/2 bg-white/5 hover:bg-white/10 text-white p-3 rounded-full backdrop-blur-md border border-white/10 opacity-0 group-hover/carousel:opacity-100 transition-opacity z-30">
                <svg class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
            </button>
            <button id="next-btn" class="absolute right-4 top-1/2 -translate-y-1/2 bg-white/5 hover:bg-white/10 text-white p-3 rounded-full backdrop-blur-md border border-white/10 opacity-0 group-hover/carousel:opacity-100 transition-opacity z-30">
                <svg class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </button>
            
            <!-- Dots / Indicadores -->
            <div id="carousel-dots" class="absolute bottom-6 left-1/2 -translate-x-1/2 flex gap-2 z-30">
                <!-- Se inyectarán aquí -->
            </div>
        </div>

        <!-- Lado de Información -->
        <div class="w-full md:w-1/3 p-6 md:p-10 flex flex-col justify-between bg-[#0f0f0f] border-t md:border-t-0 md:border-l border-white/5">
            <div>
                <h3 id="modal-title" class="text-3xl font-bold text-white mb-4"></h3>
                <p id="modal-desc" class="text-gray-400 text-base leading-relaxed mb-8"></p>
                <div id="modal-tags" class="flex flex-wrap gap-2 mb-8">
                    <!-- Se inyectarán aquí -->
                </div>
            </div>

            <div id="modal-links" class="flex flex-col gap-3">
                <!-- Se inyectarán aquí -->
            </div>
        </div>

        <!-- Botón de Cerrar -->
        <button
            id="close-modal"
            class="absolute top-4 right-4 bg-white/5 hover:bg-white/10 backdrop-blur-md text-white rounded-full p-2 transition-all border border-white/10 z-50"
            aria-label="Cerrar"
        >
            <svg class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
        </button>
    </div>
</dialog>

<script>
    interface Project {
        title: string;
        description: string;
        images: string[];
        tags: string[];
        link?: string;
        github?: string;
    }

    const modal = document.getElementById("project-modal") as HTMLDialogElement;
    const track = document.getElementById("carousel-track");
    const dotsContainer = document.getElementById("carousel-dots");
    const titleEl = document.getElementById("modal-title");
    const descEl = document.getElementById("modal-desc");
    const tagsEl = document.getElementById("modal-tags");
    const linksEl = document.getElementById("modal-links");
    const prevBtn = document.getElementById("prev-btn");
    const nextBtn = document.getElementById("next-btn");
    const closeModal = document.getElementById("close-modal");

    let currentIndex = 0;
    let currentProject: Project | null = null;

    function updateCarousel() {
        if (!track || !currentProject) return;
        track.style.transform = `translateX(-${currentIndex * 100}%)`;
        
        // Actualizar dots
        const dots = dotsContainer?.querySelectorAll("div");
        dots?.forEach((dot, idx) => {
            if (idx === currentIndex) {
                dot.classList.add("bg-white", "w-6");
                dot.classList.remove("bg-white/30", "w-2");
            } else {
                dot.classList.remove("bg-white", "w-6");
                dot.classList.add("bg-white/30", "w-2");
            }
        });
    }

    document.querySelectorAll(".project-image-container").forEach((container) => {
        container.addEventListener("click", () => {
            const data = (container as HTMLElement).dataset.project;
            if (!data || !modal) return;
            
            currentProject = JSON.parse(data);
            if (!currentProject) return;

            currentIndex = 0;

            // Inyectar imágenes
            if (track) {
                track.innerHTML = currentProject.images.map(img => `
                    <div class="min-w-full h-full flex items-center justify-center">
                        <img src="${img}" class="w-full h-full object-cover" />
                    </div>
                `).join("");
            }

            // Inyectar Dots
            if (dotsContainer) {
                dotsContainer.innerHTML = currentProject.images.map((_, i) => `
                    <div class="h-2 rounded-full transition-all duration-300 ${i === 0 ? 'bg-white w-6' : 'bg-white/30 w-2'}"></div>
                `).join("");
            }

            // Llenar información
            if (titleEl) titleEl.textContent = currentProject.title;
            if (descEl) descEl.textContent = currentProject.description;
            
            if (tagsEl) {
                tagsEl.innerHTML = currentProject.tags.map(tag => `
                    <span class="px-3 py-1 text-xs font-medium bg-white/5 border border-white/10 rounded-full text-white/80">${tag}</span>
                `).join("");
            }

            if (linksEl) {
                linksEl.innerHTML = `
                    ${currentProject.github ? `
                        <a href="${currentProject.github}" target="_blank" class="flex items-center justify-center gap-2 px-6 py-3 text-sm font-semibold text-white bg-white/5 border border-white/10 rounded-xl hover:bg-white/10 transition-all">
                            Ver Código
                        </a>
                    ` : ''}
                    ${currentProject.link ? `
                        <a href="${currentProject.link}" target="_blank" class="flex items-center justify-center gap-2 px-6 py-3 text-sm font-semibold text-black bg-white rounded-xl hover:bg-gray-200 transition-all">
                            Visitar Sitio
                        </a>
                    ` : ''}
                `;
            }

            modal.showModal();
            modal.classList.add("active");
            updateCarousel();
        });
    });

    prevBtn?.addEventListener("click", () => {
        if (!currentProject) return;
        currentIndex = (currentIndex - 1 + currentProject.images.length) % currentProject.images.length;
        updateCarousel();
    });

    nextBtn?.addEventListener("click", () => {
        if (!currentProject) return;
        currentIndex = (currentIndex + 1) % currentProject.images.length;
        updateCarousel();
    });

    const closeAll = () => {
        modal?.close();
        modal?.classList.remove("active");
    };

    closeModal?.addEventListener("click", closeAll);
    modal?.addEventListener("click", (e) => { if (e.target === modal) closeAll(); });
</script>

<style>
    dialog::backdrop {
        background: rgba(0, 0, 0, 0.9);
        backdrop-filter: blur(8px);
    }
</style>
