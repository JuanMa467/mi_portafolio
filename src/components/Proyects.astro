---
import TecnologiaPill from "./TecnologiaPill.astro";
import Github from "./icons/github.astro";

const PROJECTS = [
    {
        title: "ParkScand",
        description: `Un sistema automatizado de gestión integral para playas de estacionamiento. El núcleo del sistema está diseñado para transformar la gestión operativa mediante cuatro pilares fundamentales: control de flujo de vehículos, optimización de activos a través del monitoreo en tiempo real, gestión transaccional segura y generación de inteligencia de negocio mediante reportes detallados.`,
        link: "https://parkscan-ten.vercel.app/",
        github: "https://github.com/JuanMa467/ParkScan",
        image: "/images/parkscand.jpeg",
        tags: ["HTML", "Tailwind", "JavaScript", "React", "Supabase"],
    },
    // Puedes agregar más proyectos aquí para que aparezcan al lado
];
---

<div class=`
    grid grid-cols-1 
    md:grid-cols-2 
    gap-6 md:gap-12 bg-white/10  
    pl-4 pr-4 pt-4 pb-4 
    rounded-xl 
`>
{
    PROJECTS.map(({ title, description, image, tags, link, github }) => (
        <article class="flex flex-col group space-y-4">
            <h3 class="text-2xl font-bold text-white">{title}</h3>
            
            <div class="w-full">
                <div class="relative flex flex-col items-center transition duration-500 ease-in-out transform shadow-xl overflow-clip rounded-xl sm:rounded-xl md:group-hover:-translate-y-1 md:group-hover:shadow-2xl border border-white/10 hover:border-white/20 hover:bg-white/5">
                    <img
                        class="object-cover object-top w-full h-56 transition duration-500 sm:h-full md:scale-110 md:group-hover:scale-105"
                        src={image}
                        alt={`Captura de pantalla del proyecto ${title}`}
                    />
                </div>
            </div>

            <div class="w-full flex flex-col justify-between flex-1">
                <div>
                    <ul class="flex flex-wrap gap-2 mb-4 mt-2">
                        {tags.map((tag) => (
                            <li>
                                <TecnologiaPill>{tag}</TecnologiaPill>
                            </li>
                        ))}
                    </ul>
                    <div class="mb-4 text-white/70 text-pretty">
                        <p>{description}</p>
                    </div>
                </div>
                
                <footer class="flex items-end justify-start mt-4 gap-x-4">
                    {github && (
                        <a
                            href={github}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="flex items-center gap-2 px-4 py-2 text-sm font-medium transition text-white bg-white/5 border border-white/10 rounded-full hover:bg-white/10 hover:text-white"
                        >
                            <Github class="size-4" />
                            Código
                        </a>
                    )}
                    {link && (
                        <a
                            href={link}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="flex items-center gap-2 px-4 py-2 text-sm font-medium transition text-white bg-white/10 border border-white/10 rounded-full hover:bg-white/20 hover:text-white"
                        >
                            Saber más
                            <svg class="size-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 12H5m14 0-4 4m4-4-4-4"/>
                            </svg>
                        </a>
                    )}
                </footer>
            </div>
        </article>
    ))
}
</div>
