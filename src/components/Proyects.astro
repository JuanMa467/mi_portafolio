---
import TecnologiaPill from "./TecnologiaPill.astro";
import Github from "./icons/github.astro";

const PROJECTS = [
    {
        title: "ParkScand",
        description: `Sistema automatizado para gestionar playas de estacionamiento que controla el ingreso y egreso de vehículos, monitorea la disponibilidad en tiempo real, gestiona pagos de forma segura y genera reportes para la toma de decisiones`,
        link: "https://parkscan-ten.vercel.app/",
        github: "https://github.com/PenoffPablo/ParkScan",
        image: "/images/parkscand.jpeg",
        tags: ["HTML", "Tailwind", "JavaScript", "React", "Supabase"],
    },
];
---

<div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-12 pb-10">
    {
        PROJECTS.map(({ title, description, image, tags, link, github }) => (
            <article class="flex flex-col group p-4 rounded-xl relative overflow-hidden bg-white/5 border border-white/10">
                <div class="absolute inset-0 bg-white transition-all duration-1000 ease-out bg-[size:16px_16px] bg-[position:0_0,8px_8px] bg-[image:linear-gradient(45deg,#efefef_25%,rgba(239,239,239,0)_25%,rgba(239,239,239,0)_75%,#efefef_75%,#efefef),linear-gradient(45deg,#efefef_25%,rgba(239,239,239,0)_25%,rgba(239,239,239,0)_75%,#efefef_75%,#efefef)] [clip-path:polygon(0px_0px,0%_0px,0%_100%,0px_100%)]  z-0 pointer-events-none" />
                <div class="relative z-10 flex flex-col h-full space-y-4">
                    <h3 class="text-2xl font-bold text-white transition-colors duration-500">
                        {title}
                    </h3>

                    <div class="w-full">
                        <div class="relative flex flex-col items-center transition duration-500 ease-in-out transform shadow-xl overflow-clip rounded-xl sm:rounded-xl md:group-hover:-translate-y-1 md:group-hover:shadow-2xl border border-white/10 hover:border-white/20 hover:bg-white/5">
                            <img
                                class="object-cover object-top w-full h-56 transition duration-500 sm:h-full scale-100 group-hover:scale-110"
                                src={image}
                                alt={`Captura de pantalla del proyecto ${title}`}
                            />
                        </div>
                    </div>

                    <div class="w-full flex flex-col justify-between flex-1">
                        <div>
                            <ul class="flex flex-wrap gap-2 mb-4 mt-2">
                                {tags.map((tag) => (
                                    <li>
                                        <TecnologiaPill>{tag}</TecnologiaPill>
                                    </li>
                                ))}
                            </ul>
                            <div class="mb-4 text-white/95 text-pretty">
                                <p>{description}</p>
                            </div>
                        </div>

                        <footer class="flex items-end justify-start mt-4 gap-x-4">
                            {github && (
                                <a
                                    href={github}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="flex items-center gap-2 px-4 py-2 text-sm font-medium transition text-white bg-white/5 border border-white/10 rounded-full hover:bg-white/10 hover:text-white"
                                >
                                    <Github class="size-4" />
                                    Código
                                </a>
                            )}
                            {link && (
                                <a
                                    href={link}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="flex items-center gap-2 px-4 py-2 text-sm font-medium transition text-white bg-white/10 border border-white/10 rounded-full hover:bg-white/20 hover:text-white"
                                >
                                    Saber más
                                    <svg
                                        class="size-4"
                                        aria-hidden="true"
                                        xmlns="http://www.w3.org/2000/svg"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke="currentColor"
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M19 12H5m14 0-4 4m4-4-4-4"
                                        />
                                    </svg>
                                </a>
                            )}
                        </footer>
                    </div>
                </div>
            </article>
        ))
    }
</div>
