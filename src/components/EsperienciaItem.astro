---
interface Props {
    data: string;
    title: string;
    description: string;
    link?: string;
    image: string;
    images?: string[];
}

const { data, title, description, link, image, images } = Astro.props;
---

<div
    class="absolute w-3 h-3 bg-white rounded-full mt-1.5 -start-1.5 border border-buffer"
>
</div>
<time class="ml-2 text-sm font-normal text-white leading-none text-body"
    >{data}</time
>
<h3 class="text-lg font-semibold text-white text-heading my-2">{title}</h3>
<p class="my-2 mb-4 text-base font-normal text-white/80 text-pretty">
    {description}
</p>
<div class="mb-4">
    <div
        class="relative group cursor-zoom-in experience-trigger overflow-hidden rounded-lg"
        data-experience={JSON.stringify({
            title,
            description,
            images: images || [image],
            link,
            data,
        })}
    >
        <img
            class="transition-all duration-300 w-full object-contain h-48 bg-black/20"
            src={image}
            alt={title}
        />
        <div
            class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center z-20"
        >
            <span
                class="text-white font-medium bg-black/50 px-4 py-2 rounded-full backdrop-blur-sm border border-white/20"
            >
                Ver Galería
            </span>
        </div>
    </div>
</div>
{
    link && (
        <a
            href={link}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center text-body bg-neutral-secondary-medium box-border border border-default-medium transition-all duration-300 hover:-translate-y-1 hover:brightness-125 hover:text-white hover:shadow-lg focus-visible:ring-2 focus-visible:ring-white/30 shadow-xs font-medium leading-5 rounded-base text-sm px-4 py-2.5 focus:outline-none"
        >
            Saber más ...{" "}
            <svg
                class="w-4 h-4 ms-1.5 -me-0.5"
                aria-hidden="true"
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                fill="none"
                viewBox="0 0 24 24"
            >
                <path
                    stroke="currentColor"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M19 12H5m14 0-4 4m4-4-4-4"
                />
            </svg>
        </a>
    )
}
