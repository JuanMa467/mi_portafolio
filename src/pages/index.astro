---
import Layout from "../layouts/Layout.astro";
import Badge from "../components/Badge.astro";
import Github from "../components/icons/github.astro";
import Linkedin from "../components/icons/linkedin.astro";
import SocialPill from "../components/SocialPill.astro";
import Mail from "../components/icons/mail.astro";
import Proyects from "../components/Proyects.astro";
import Exp from "../components/Experecias.astro";
import SectionContainer from "../components/SectionContainer.astro";
import BriefCase from "../components/icons/BriefCase.astro";
import Code from "../components/icons/code.astro";
import Skills from "../components/skills.astro";
import Loader from "../components/Loader.astro";
import LineaAbajo from "../components/LineAbajo.astro";
---

<Layout
	title="Portafolio Juan Manuel Atencio - Desarrollador y programador web"
	description="Contrata a Juan Manuel Atencio para desarrollar tus proyectos web"
>
	<SectionContainer className="px-4 pb-24 reveal">
		<main class="">
			<Loader />
			<h2 class="text-1xl md:text-xl lg:text-xl opacity-80 text-white">
				Soy Desarrollador de Software.
				<a
					href="https://www.linkedin.com/in/juan-manuel-atencio-81bb3a260/"
					target="_blank"
					rel="noopener"
					class="pl-2 mb-2"
				>
					<Badge>Disponible para trabajar</Badge>
				</a>
				<br />
				Te ayudo a transformar tus ideas en código escalable.
			</h2>
			<ul
				class="text-white text-sm md:text-md lg:text-md items-center flex flex-wrap gap-x-4 gap-y-4 py-4"
			>
				<li>
					<SocialPill
						href="https://github.com/JuanMa467"
						target="_blank"
						rel="noopener noreferrer"
					>
						<Github class="size-6" />
						Github
					</SocialPill>
				</li>
				<li class="ml-3">
					<SocialPill
						href="https://www.linkedin.com/in/juan-manuel-atencio-81bb3a260/"
						target="_blank"
						rel="noopener noreferrer"
					>
						<Linkedin class="size-6" />
						Linkedin
					</SocialPill>
				</li>
				<li class="ml-3">
					<SocialPill
						href="https://mail.google.com/mail/?view=cm&fs=1&to=atenciojuanmanuel05@gmail.com"
						target="_blank"
						rel="noopener noreferrer"
					>
						<Mail class="size-6" />
						atenciojuanmanuel05@gmail.com
					</SocialPill>
				</li>
			</ul>
		</main>
	</SectionContainer>
	<SectionContainer id="experiencia" className="px-4 reveal">
		<h2
			class="text-2xl font-semibold mb-6 flex gap-x-2 items-center text-white"
		>
			<BriefCase class="size-7" />
			<div class="ml-2">
				<h2 class="text-3xl md:text-4xl font-bold text-white">
					Mis <span style="color: var(--accent)">Experiencias</span>
				</h2><LineaAbajo />
			</div>
		</h2>
		<Exp />
	</SectionContainer>
	<SectionContainer id="proyectos" className="px-4 reveal">
		<h2
			class="text-2xl font-semibold mb-6 text-white flex gap-x-2 items-center"
		>
			<Code class="size-7" />
			<div class="ml-2">
				<h2 class="text-3xl md:text-4xl font-bold text-white">
					Mis <span style="color: var(--accent)">Proyectos</span>
				</h2>
				<LineaAbajo />
			</div>
		</h2>
		<Proyects />
	</SectionContainer>
	<SectionContainer id="habilidades" className="px-4 pb-10 reveal">
		<h2
			class="text-2xl font-semibold mb-6 text-white flex gap-x-2 items-center"
		>
			<Code class="size-7" />
			<div class="ml-2">
				<h2 class="text-3xl md:text-4xl font-bold text-white">
					Mis <span style="color: var(--accent)">Habilidades</span>
				</h2>
				<LineaAbajo />
			</div>
		</h2>
		<Skills />
	</SectionContainer>
</Layout>
